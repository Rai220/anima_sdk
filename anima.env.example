# Copy this file to anima.env and edit it, or set the same variables directly
# in the shell before running run.sh, loop.sh, or meta_loop.sh.

# Built-in harnesses: free_code, claude, codex, deepagents, custom.
ANIMA_HARNESS=free_code

# Optional. If empty, the selected CLI uses its own default model.
# Codex example:
# ANIMA_MODEL=gpt-5.5
# Claude example:
# ANIMA_MODEL=claude-opus-4-7
# Deepagents: используйте формат provider:model. В non-interactive режиме
# CLI не подхватывает глобальный default-model и без префикса падает с
# "Unable to infer a model provider".
# ANIMA_MODEL=anthropic:claude-opus-4-7
# ANIMA_MODEL=openai:gpt-4o
# ANIMA_MODEL=gigachat:GigaChat-3-Ultra

# Prompt file passed to the harness. Relative paths are resolved from the task
# directory or generation directory.
ANIMA_PROMPT_FILE=MAIN_GOAL.md

# Binary overrides.
# ANIMA_FREE_CODE_BIN=free-code
# ANIMA_CLAUDE_BIN=claude
# ANIMA_CODEX_BIN=codex
# ANIMA_DEEPAGENTS_BIN=deepagents

# Autonomous run defaults. Set to 0 to disable.
ANIMA_SKIP_PERMISSIONS=1
ANIMA_CODEX_FULL_AUTO=1
ANIMA_CODEX_SKIP_GIT_REPO_CHECK=1

# Deepagents-specific knobs (optional).
# ANIMA_DEEPAGENTS_AGENT=coder
# ANIMA_DEEPAGENTS_AUTO_APPROVE=1
# ANIMA_DEEPAGENTS_SHELL_ALLOW=all
# ANIMA_DEEPAGENTS_MAX_TURNS=20
# ANIMA_DEEPAGENTS_QUIET=0

# Extra args are split by the shell. For complex quoting, prefer custom.
# ANIMA_FREE_CODE_ARGS=
# ANIMA_CLAUDE_ARGS=
# ANIMA_CODEX_ARGS=
# ANIMA_DEEPAGENTS_ARGS=

# For any other harness. When this is set, ANIMA_HARNESS is treated as custom.
# The command runs through bash -lc from the task directory with the prompt
# also available as stdin and at $ANIMA_PROMPT_FILE.
# ANIMA_HARNESS_CMD='my-agent --task-file "$ANIMA_PROMPT_FILE"'
